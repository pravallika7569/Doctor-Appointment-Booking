<!doctype html>
<html><head><meta charset="utf-8"><title>Doctor Dashboard</title><script src="https://cdn.tailwindcss.com"></script></head>
<body class="bg-slate-50 min-h-screen"><div class="max-w-4xl mx-auto p-6">
  <div class="flex justify-between"><h2>Dr Dashboard</h2><a href="/logout" class="text-red-500">Logout</a></div>
  {% if doctor %}
  <div class="mt-4 p-4 bg-white rounded shadow">
    <h3 class="text-lg font-semibold">{{ doctor.name }}</h3>
    <p>{{ doctor.specialization }} — Rating: {{ doctor.rating }} ({{ doctor.reviews }})</p>
    <p class="mt-2">{{ doctor.bio }}</p>
  </div>
  {% endif %}
  <h3 class="mt-6">Appointments</h3>
  <ul class="mt-2">
    {% for a in appointments %}
      <li class="p-2 bg-white rounded shadow mb-2">#{{ a._id }} — Patient: {{ a.patient_id }} — {{ a.symptoms }}</li>
    {% else %}
      <li>No appointments.</li>
    {% endfor %}
  </ul>
</div></body></html>
