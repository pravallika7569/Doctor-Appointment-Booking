<!doctype html>
<html><head><meta charset="utf-8"><title>Doctors</title><script src="https://cdn.tailwindcss.com"></script></head>
<body class="bg-slate-50 min-h-screen"><div class="max-w-4xl mx-auto p-6">
  <h2 class="text-2xl mb-4">Find Doctors</h2>
  <ul>
    {% for d in doctors %}
      <li class="p-3 bg-white rounded shadow mb-2">
        <a class="font-semibold" href="/doctor/{{ d._id }}">{{ d.name }}</a>
        <div class="text-sm">{{ d.specialization }} — Rating: {{ d.rating }} ({{ d.reviews }})</div>
        <p class="mt-2">{{ d.bio }}</p>
      </li>
    {% else %}
      <li>No doctors found.</li>
    {% endfor %}
  </ul>
</div></body></html>
