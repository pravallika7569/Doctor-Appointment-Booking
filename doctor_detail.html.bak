<!doctype html>
<html><head><meta charset="utf-8"><title>{{ doctor.name }}</title><script src="https://cdn.tailwindcss.com"></script></head>
<body class="bg-slate-50 min-h-screen"><div class="max-w-2xl mx-auto p-6">
  <h2 class="text-2xl">{{ doctor.name }}</h2>
  <p class="text-sm">{{ doctor.specialization }} — Rating: {{ doctor.rating }} ({{ doctor.reviews }})</p>
  <p class="mt-2">{{ doctor.bio }}</p>
  <a href="/book/{{ doctor._id }}" class="px-3 py-2 bg-blue-600 text-white rounded">Book Appointment</a>
  <h3 class="mt-6">Rate this doctor</h3>
  <form method="post" action="/rate/{{ doctor._id }}">
    <select name="score" class="p-2 border rounded">
      <option value="5">5</option><option value="4">4</option><option value="3">3</option><option value="2">2</option><option value="1">1</option>
    </select>
    <button class="px-3 py-2 bg-green-600 text-white rounded">Submit</button>
  </form>
</div></body></html>
