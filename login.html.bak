<!doctype html>
<html><head><meta charset="utf-8"><title>Login</title><script src="https://cdn.tailwindcss.com"></script></head>
<body class="bg-slate-50 min-h-screen">
  <div class="max-w-md mx-auto p-6 bg-white rounded shadow mt-10">
    <h2 class="text-xl mb-4">Login</h2>
    <form method="post">
      {{ form.csrf_token }}
      <div class="mb-2">{{ form.email(class_='w-full p-2 border rounded') }}</div>
      <div class="mb-2">{{ form.password(class_='w-full p-2 border rounded') }}</div>
      <div>{{ form.submit(class_='px-4 py-2 bg-blue-600 text-white rounded') }}</div>
    </form>
    <p class="mt-4"><a href="/reset_request" class="text-blue-600">Forgot password?</a></p>
  </div>
</body>
</html>
