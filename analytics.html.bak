<!doctype html>
<html><head><meta charset="utf-8"><title>Analytics</title><script src="https://cdn.tailwindcss.com"></script></head>
<body class="bg-slate-50 min-h-screen"><div class="max-w-4xl mx-auto p-6">
  <h2 class="text-2xl">Analytics</h2>
  <div class="grid grid-cols-3 gap-4 mt-4">
    <div class="p-4 bg-white rounded shadow">Users<br/><strong>{{ total_users }}</strong></div>
    <div class="p-4 bg-white rounded shadow">Doctors<br/><strong>{{ total_doctors }}</strong></div>
    <div class="p-4 bg-white rounded shadow">Appointments<br/><strong>{{ total_appointments }}</strong></div>
  </div>
  <h3 class="mt-6">Top Doctors</h3>
  <ul class="mt-2">
    {% for d in top_docs %}
      <li class="p-2 bg-white rounded shadow mb-2">{{ d.name }} — {{ d.rating }}</li>
    {% endfor %}
  </ul>
</div></body></html>
