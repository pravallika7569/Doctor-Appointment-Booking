<!doctype html><html><head><meta charset="utf-8"><title>Reset</title><script src="https://cdn.tailwindcss.com"></script></head><body class="bg-slate-50 min-h-screen"><div class="max-w-md mx-auto p-6 bg-white rounded mt-10">
  <h2>Request Password Reset</h2>
  <form method="post">{{ form.csrf_token }}{{ form.email(class_='w-full p-2 border rounded')}}{{ form.submit(class_='px-3 py-2 bg-blue-600 text-white rounded mt-2') }}</form>
</div></body></html>
